# iTick API — 注册地址：https://itick.org
# 注册后在控制台复制 API Token 填入下方
ITICK_TOKEN=your_itick_token_here

# 同步间隔（秒），默认每 6 小时同步一次新股列表
SYNC_INTERVAL_SECONDS=21600

# 数据库路径（默认当前目录）
DATABASE_URL=sqlite:///./xingu.db

# ─── 搜狗反爬配置（本地开发） ─────────────────────────────────────────────────
#
# 问题根源：搜狗会封禁数据中心 IP（如 AWS、阿里云等云服务器的 IP）。
# 解决方案（任选其一）：
#
# 方案 A：配置本地代理（推荐，本地开发用）
#   如果你用 ClashX Pro / Clash 等代理工具，开启其 HTTP 代理模式（通常是 7890 端口），
#   然后填写下方 SOGOU_PROXY。程序会自动探测 7890/7891/1080 等常用端口，
#   也可手动指定：
SOGOU_PROXY=
# 示例：
#   SOGOU_PROXY=http://127.0.0.1:7890    # ClashX HTTP 代理
#   SOGOU_PROXY=socks5://127.0.0.1:7891  # ClashX SOCKS5 代理
#
# 方案 B：配置 Cookie（辅助手段，配合方案 A 效果更好）
#   获取方法：用浏览器访问 https://weixin.sogou.com，打开 DevTools → Network
#   → 任意请求 → Request Headers → Cookie，复制整行粘贴到下方。
#   注意：Cookie 约 12-24 小时过期，程序检测到反爬时会自动用 Playwright 刷新。
SOGOU_COOKIE=
#
# 方案 C：部署到国内/香港云服务器
#   搜狗不封禁国内 IDC IP，部署后无需以上任何配置即可正常抓取。
